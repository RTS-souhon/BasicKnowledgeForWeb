{
    "name": "backend",
    "version": "0.0.0",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "scripts": {
        "dev": "wrangler dev --port 8080",
        "deploy": "wrangler deploy --env prod --minify",
        "deploy:dev": "wrangler deploy --env dev --minify",
        "build": "wrangler deploy --dry-run",
        "lint": "biome check ./src",
        "lint:fix": "biome check --write --unsafe ./src",
        "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
        "test": "jest",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:check": "drizzle-kit check",
        "db:up": "drizzle-kit up",
        "db:drop": "drizzle-kit drop"
    },
    "dependencies": {
        "@hono/zod-validator": "^0.7.6",
        "@types/bcryptjs": "^3.0.0",
        "bcryptjs": "^3.0.2",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^1.0.0-beta.19",
        "hono": "^4.12.9",
        "pg": "^8.20.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/pg": "^8.18.0",
        "bun-types": "^1.3.11",
        "drizzle-kit": "^1.0.0-beta.18-905b79a",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2"
    }
}
