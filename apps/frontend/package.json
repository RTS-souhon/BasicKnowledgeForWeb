{
    "name": "frontend",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "start": "next start",
        "lint": "biome check ./app",
        "lint:fix": "biome check --write --unsafe ./app",
        "build": "next build",
        "build:cloudflare": "opennextjs-cloudflare build",
        "dev": "bun run build:cloudflare && wrangler dev --port 8771",
        "preview": "bun run build:cloudflare && bun run dev",
        "deploy": "bun run build:cloudflare && wrangler deploy --env prod",
        "deploy:dev": "bun run build:cloudflare && wrangler deploy --env dev",
        "type-check": "tsc --noEmit",
        "test": "echo 'No tests configured yet'"
    },
    "dependencies": {
        "@opennextjs/cloudflare": "^1.11.0",
        "backend": "^0.0.0",
        "hono": "^4.10.1",
        "next": "15.5.6",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20251014.0",
        "@tailwindcss/postcss": "^4.1.14",
        "@types/node": "^24.6.2",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "postcss": "^8",
        "tailwindcss": "^4.1.14",
        "tsx": "^4.20.6",
        "typescript": "^5",
        "wrangler": "^4.43.0"
    }
}
