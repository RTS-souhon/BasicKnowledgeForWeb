{
    "name": "frontend",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "start": "next start",
        "lint": "biome check ./app",
        "lint:fix": "biome check --write --unsafe ./app",
        "build": "next build",
        "build:cloudflare": "opennextjs-cloudflare build",
        "dev": "bun run build:cloudflare && wrangler dev --port 8771",
        "preview": "bun run build:cloudflare && bun run dev",
        "deploy": "bun run build:cloudflare && wrangler deploy --env prod",
        "deploy:dev": "bun run build:cloudflare && wrangler deploy --env dev",
        "type-check": "tsc --noEmit",
        "test": "jest --forceExit",
        "test:watch": "jest --watch --forceExit"
    },
    "dependencies": {
        "@base-ui/react": "^1.3.0",
        "@hookform/resolvers": "^5.2.2",
        "@opennextjs/cloudflare": "^1.18.1",
        "backend": "^0.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "hono": "^4.12.12",
        "lucide-react": "^1.6.0",
        "next": "15.5.14",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-hook-form": "^7.72.1",
        "shadcn": "^4.1.2",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "cross-fetch": "^4.1.0",
        "jest-environment-jsdom": "^30.3.0",
        "msw": "^2.12.14",
        "postcss": "^8",
        "tailwindcss": "^4.2.2",
        "typescript": "^5"
    }
}
