{
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "types": ["jest", "@testing-library/jest-dom"],
        "baseUrl": "./",
        "paths": {
            "@frontend/*": ["*"],
            "@backend/*": ["../backend/*"]
        }
    },
    "include": ["tests/**/*", "app/**/*", "jest.config.ts", "jest.polyfills.ts", "jest.setup.ts"]
}
