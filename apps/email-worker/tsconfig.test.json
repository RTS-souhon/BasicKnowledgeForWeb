{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "lib": ["ESNext", "DOM"],
        "types": ["jest", "node"],
        "esModuleInterop": true,
        "baseUrl": ".",
        "paths": {
            "@email-worker/*": ["./*"]
        }
    },
    "include": ["tests/**/*", "src/**/*"]
}
